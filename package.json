{
  "name": "marz-front",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev",
    "build": "vite build && (test -d .output/server && cp instrument.server.mjs .output/server/ || true)",
    "preview": "vite preview",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "lint": "eslint .",
    "knip": "knip --config knip.jsonc",
    "react-doctor": "bash -o pipefail -c 'npx -y react-doctor@0.1.6 . | tee /tmp/marz-react-doctor-report.txt; scan_status=${PIPESTATUS[0]}; node --import tsx scripts/react-doctor-score-report.ts /tmp/marz-react-doctor-report.txt --min-score 95; report_status=$?; if [ \"$scan_status\" -ne 0 ]; then exit \"$scan_status\"; fi; exit \"$report_status\"'",
    "react-doctor:report": "node --import tsx scripts/react-doctor-score-report.ts",
    "check:exact-deps": "node scripts/check-exact-deps.mjs",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "api:sync": "tsx scripts/sync-api.ts",
    "api:generate": "orval",
    "check:api-direct": "tsx scripts/check-direct-api-calls.ts",
    "check:i18n-standards": "tsx scripts/check-i18n-standards.ts",
    "check:i18n-standards:self-test": "tsx scripts/check-i18n-standards.ts --self-test",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile",
    "work:pre": "pnpm api:sync",
    "work:post": "pnpm format && pnpm i18n:extract && pnpm i18n:compile && pnpm quality-gates",
    "quality-gates": "pnpm check:exact-deps && pnpm lint && pnpm check && pnpm typecheck && pnpm react-doctor && pnpm test && pnpm test:e2e && pnpm knip && pnpm check:api-direct && pnpm check:i18n-standards",
    "prepare": "husky"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "1.1.5",
    "@discordapp/twemoji": "16.0.1",
    "@fontsource/geist-mono": "5.1.0",
    "@fontsource/geist-sans": "5.1.0",
    "@grafana/faro-web-sdk": "2.6.3",
    "@grafana/faro-web-tracing": "2.6.3",
    "@intercom/messenger-js-sdk": "0.0.19",
    "@lingui/core": "5.9.5",
    "@lingui/detect-locale": "5.9.5",
    "@lingui/react": "5.9.5",
    "@sentry/tanstackstart-react": "10.53.1",
    "@t3-oss/env-core": "0.13.10",
    "@tailwindcss/vite": "4.1.18",
    "@tanstack/react-devtools": "0.10.2",
    "@tanstack/react-form": "1.29.0",
    "@tanstack/react-query": "5.99.2",
    "@tanstack/react-query-devtools": "5.99.2",
    "@tanstack/react-router": "1.168.23",
    "@tanstack/react-router-devtools": "1.166.13",
    "@tanstack/react-router-ssr-query": "1.166.11",
    "@tanstack/react-start": "1.167.42",
    "@tanstack/react-virtual": "3.13.24",
    "@tanstack/router-plugin": "1.167.22",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "libphonenumber-js": "1.13.7",
    "lucide-react": "0.577.0",
    "posthog-js": "1.391.9",
    "radix-ui": "1.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-grab": "0.1.32",
    "recharts": "3.8.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.0.2",
    "tailwindcss": "4.1.18",
    "tw-animate-css": "1.3.6",
    "zod": "4.3.6",
    "zustand": "5.0.0"
  },
  "devDependencies": {
    "@clerk/testing": "2.0.20",
    "@lingui/cli": "5.9.5",
    "@lingui/swc-plugin": "5.11.0",
    "@lingui/vite-plugin": "5.9.5",
    "@playwright/test": "1.59.1",
    "@tailwindcss/typography": "0.5.16",
    "@tanstack/eslint-config": "0.4.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.10.2",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitejs/plugin-react-swc": "4.3.0",
    "axe-core": "4.12.1",
    "axe-playwright": "2.2.2",
    "eslint": "10.2.1",
    "eslint-plugin-lingui": "0.13.1",
    "husky": "9.1.7",
    "jsdom": "28.1.0",
    "knip": "6.12.1",
    "lint-staged": "16.4.0",
    "nitro": "3.0.260522-beta",
    "orval": "8.8.0",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.7.2",
    "vite": "8.0.0",
    "vitest": "3.0.5",
    "vitest-axe": "0.1.0",
    "yaml": "2.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
